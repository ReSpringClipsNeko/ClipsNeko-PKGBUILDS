# Maintainer: zlicdt <xkicdt1@gmail.com>

pkgname=clipsneko-hooks
pkgver=2026.02.16
pkgrel=1
pkgdesc='ClipsNeko Linux libalpm hooks'
groups=('clipsneko')
makedepends=('git')
depends=('systemd')
arch=('any')
license=(GPL-3.0-or-later)
url="https://github.com/ReSpringClipsNeko/${pkgname}/"
source=("git+https://github.com/ReSpringClipsNeko/clipsneko-hooks#tag=$pkgver")
sha512sums=('e8afb48c3bdc1990991419228076c6fdbc06d6a7b36a71fe82fb94dcc55a653879f752b8953e69ca3b174cb48c7b868d17525a57fe9198fee32656821c459591')

package() {
  cd "$pkgname"

  install -Dm644 clipsneko-branding.hook "$pkgdir/usr/share/libalpm/hooks/clipsneko-branding.hook"
  install -Dm644 clipsneko-plymouth-initramfs.hook "$pkgdir/usr/share/libalpm/hooks/clipsneko-plymouth-initramfs.hook"
  install -Dm644 clipsneko-reboot-required.hook "$pkgdir/usr/share/libalpm/hooks/clipsneko-reboot-required.hook"
  install -Dm644 lsb-release.hook "$pkgdir/usr/share/libalpm/hooks/lsb-release.hook"
  install -Dm644 os-release.hook "$pkgdir/usr/share/libalpm/hooks/os-release.hook"
  install -Dm755 clipsneko-branding "$pkgdir/usr/share/libalpm/scripts/clipsneko-branding"
  install -Dm755 clipsneko-reboot-required "$pkgdir/usr/share/libalpm/scripts/clipsneko-reboot-required"
  install -Dm755 update-initramfs "$pkgdir/usr/bin/update-initramfs"
}
